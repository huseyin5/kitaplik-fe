# API origin used by the frontend in PRODUCTION builds.
# In dev this is unset and Vite proxies /api + /health to the backend
# (see vite.config.js / VITE_PROXY_TARGET).
# VITE_API_BASE_URL=https://api.example.com

# Dev-only: backend the Vite proxy forwards to (default http://localhost:3000)
# VITE_PROXY_TARGET=http://localhost:3000
